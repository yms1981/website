<IfModule mod_rewrite.c>
  RewriteEngine On
  # Sin RewriteBase: Apache usa la carpeta del .htaccess (/website/ en XAMPP, / en raíz del dominio).

  # API primero: si no, carpetas reales como /api/orders/ activan -d, se salta el rewrite y un POST
  # puede redirigirse a GET (pérdida del body) → respuesta equivocada tipo GET /api/orders ({"orders":[]}).

  RewriteRule ^api/auth/login$ api/auth/login.php [L]
  RewriteRule ^api/auth/logout$ api/auth/logout.php [L]
  RewriteRule ^api/auth/register$ api/auth/register.php [L]
  RewriteRule ^api/cart$ api/cart/index.php [L]
  RewriteRule ^api/categories$ api/categories/index.php [L]
  RewriteRule ^api/contact$ api/contact/index.php [L]
  RewriteRule ^api/orders/?$ api/orders/index.php [L]
  RewriteRule ^api/warmup$ api/warmup/index.php [L]
  RewriteRule ^api/whatsapp$ api/whatsapp/index.php [L]
  RewriteRule ^api/products$ api/products/index.php [L]
  RewriteRule ^api/products/([0-9]+)$ api/products/detail.php?id=$1 [QSA,L]
  RewriteRule ^api/admin/registrations$ api/admin/registrations/index.php [L]

  RewriteRule ^api/(.*)$ api.php?__path=$1 [QSA,L]

  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  RewriteRule ^(.*)$ index.php?__path=$1 [QSA,L]
</IfModule>
