# Copia este archivo a .env y rellena los valores (sin subir .env al repositorio).
# APP_DEBUG=1 muestra el error PHP en pantalla (solo desarrollo).

APP_DEBUG=0
# Log detallado al sincronizar clientes (POST /api/customers/sync); también con APP_DEBUG=1
CUSTOMER_SYNC_LOG=0
# Archivos de log en /log/: api-*.log (API), app-*.log (sistema), sync-*.log (sincronización clientes)

FULLVENDOR_BASE_URL=https://example.com/
FULLVENDOR_TOKEN=
FULLVENDOR_COMPANY_ID=
# URLs públicas de imágenes (recomendado con FULLVENDOR_DATA_SOURCE=db; incluir company_id en la ruta si aplica)
# FULLVENDOR_IMAGES_PRODUCTS_URL=https://app.fullvendor.com/uploads/products/77/
# FULLVENDOR_IMAGES_CATEGORIES_URL=https://app.fullvendor.com/uploads/categories/77/
#
# Origen del catálogo (home, /api/products, /api/categorylist, ficha de producto):
#   api = HTTP (categoryList + wcproductList + productDetails).
#   db  = consultas directas a MySQL (FULLVENDOR_DB_*). Ajusta tablas/columnas a tu esquema (lib/FullVendorDb.php).
# Login, carrito, pedidos, alta de cliente y sync clientes/usersList siguen usando la API → mantén BASE_URL y TOKEN.
# FULLVENDOR_DATA_SOURCE=api
#
# MySQL de FullVendor (solo si FULLVENDOR_DATA_SOURCE=db)
# Esquema alineado con categories / products / product_images / catalog / companies (ver lib/FullVendorDb.php).
# FULLVENDOR_DB_HOST=127.0.0.1
# FULLVENDOR_DB_PORT=3306
# FULLVENDOR_DB_NAME=
# FULLVENDOR_DB_USER=
# FULLVENDOR_DB_PASS=
# FULLVENDOR_DB_TABLE_PREFIX=
# URL pública del sitio FullVendor para armar pic = .../uploads/products/{company_id}/{archivo} (si vacío → FULLVENDOR_BASE_URL)
# FULLVENDOR_DB_FILES_BASE_URL=https://tu-dominio-fullvendor.com/
# Tablas (nombres por defecto del core FullVendor)
# FULLVENDOR_DB_TABLE_CATEGORIES=categories
# FULLVENDOR_DB_TABLE_PRODUCTS=products
# FULLVENDOR_DB_TABLE_PRODUCT_IMAGES=product_images
# FULLVENDOR_DB_TABLE_CATALOG=catalog
# FULLVENDOR_DB_TABLE_COMPANIES=companies
# Tabla grupos de cliente (modo db + sync → customer_groups local)
# FULLVENDOR_DB_TABLE_CUSTOMER_GROUP=customer_group
# Pedidos desde BD (GET /api/orders/from-db). Si tu tabla se llama warehouseorders:
# FULLVENDOR_DB_TABLE_ORDERS=warehouseorders
# FULLVENDOR_DB_TABLE_ORDER_DETAILS=order_details
# FULLVENDOR_DB_TABLE_CUSTOMERS=customers
# FULLVENDOR_DB_TABLE_STATUS_ORDERS=status_orders
# Sin JOIN a status_orders (si la tabla no existe en tu esquema): FULLVENDOR_DB_ORDERS_SKIP_STATUS_JOIN=1
# Vendedor en listado de pedidos: por defecto JOIN vendors solo por orders.user_id = vendors.user_id.
# Si tienes user_id duplicados entre compañías y necesitas acotar: FULLVENDOR_DB_VENDOR_JOIN_MATCH_ORDER_COMPANY=1
# Detalle de pedido (GET .../api/orders/from-db/{order_id}): la URL debe ser el order_id de FullVendor (mismo en orders y order_details).
# Columna FK en order_details hacia el pedido (por defecto order_id). Solo si tu esquema usa otro nombre de columna.
# FULLVENDOR_DB_ORDER_DETAILS_FK_COLUMN=order_id
# Si la tabla orders no tiene columna `id` y falla el SELECT del detalle: FULLVENDOR_DB_ORDERS_SKIP_INTERNAL_ID_SELECT=1
# Si el pedido existe pero company_id en BD no coincide con FULLVENDOR_COMPANY_ID: FULLVENDOR_DB_ORDER_DETAIL_IGNORE_COMPANY=1
# Por defecto el detalle NO filtra tipo_d. Para aplicar FULLVENDOR_DB_ORDERS_TIPO_D: FULLVENDOR_DB_ORDERS_DETAIL_USE_TIPO_D=1
# Filtrar por tipo_d (vacío = no filtrar). Ej. borradores como en la app móvil: D
# FULLVENDOR_DB_ORDERS_TIPO_D=D
# Si orders no tiene company_id alineado con FULLVENDOR_COMPANY_ID: FULLVENDOR_DB_ORDERS_IGNORE_COMPANY=1
# POST lista grupos (modo api); por defecto customergroupsList
# FULLVENDOR_CUSTOMER_GROUPS_LIST_ENDPOINT=customergroupsList
# Si la primera llamada con language_id viene vacía, reintenta solo con company_id (1=activo)
# FULLVENDOR_CUSTOMER_GROUPS_TRY_NO_LANGUAGE=1
# Si con company_id estricto no hay filas en customer_group remota, segunda consulta sin filtro de compañía (1=activo)
# FULLVENDOR_DB_CUSTOMER_GROUP_RELAX_COMPANY=1
# Nombre del registro en `catalog` para catalog_id (wcproductList_post)
# FULLVENDOR_DB_CATALOG_NAME=FullVendor Catalog
# 1 = filtrar categorías por language_id además de company_id; 0 = solo company_id (como categoriesList_post puro)
# FULLVENDOR_DB_CATEGORIES_FILTER_LANGUAGE=1
#
# Endpoint POST solo con company_id (por defecto softcustomerList; si tu API usa otro nombre, cámbialo)
FULLVENDOR_SOFT_CUSTOMER_LIST_ENDPOINT=softcustomerList
# Lista de usuarios (POST con company_id); sincronización POST /api/usersList/sync
FULLVENDOR_USERS_LIST_ENDPOINT=usersList
# Volcado de respuestas API en data/cache/fv-*.json:
# 0 = desactivado (recomendado en producción / muchos usuarios; no crece el disco por cada vista)
# lists = solo categoryList, productList, softcustomerList y usersList (pocas rutas, archivos sobrescritos)
# 1 o all = todas las llamadas (login, carrito, detalle por product_id… → muchos archivos)
FULLVENDOR_SAVE_API_JSON=0
# Listados públicos: API o BD según FULLVENDOR_DATA_SOURCE (sin caché disco de listados salvo fv-* si FULLVENDOR_SAVE_API_JSON).
# Windows/XAMPP: ruta al php.exe para sync catálogo opcional en BD (POST /api/catalog/sync). Si falla, prueba: C:\xampp\php\php.exe
# PHP_CLI_PATH=
# Segundos tras los cuales un job catalog_sync_state=running se considera colgado y se libera (por defecto 2700).
# CATALOG_SYNC_STALE_SECONDS=2700

# --- Sincronización cada 10 min (cron / Task Scheduler) ---
# Script: scripts/periodic_fullvendor_sync.php o scripts/run_periodic_sync.bat
# Windows: Programador de tareas → cada 10 min → el .bat (edita la ruta de php.exe dentro).
# Linux: crontab -e → línea con php y periodic_fullvendor_sync.php
# PERIODIC_SYNC_ENABLED=1
# PERIODIC_SYNC_CATALOG=0  (1 = además volcar catálogo a MySQL catalog_*; la web no las usa para listar)
# PERIODIC_SYNC_CUSTOMERS=1
# PERIODIC_SYNC_USERSLIST=1
# PERIODIC_SYNC_CUSTOMER_GROUPS=1
# Tras GET /api/products o /api/categorylist: refresco en segundo plano de clientes + sellers (usersList), como mucho cada N s (0 = desactivado).
# BACKGROUND_CUSTOMER_USERS_SYNC_SEC=600
# HTTP opcional (misma lógica): GET/POST .../api/cron/fullvendor-sync?key=TU_SECRETO
# Header alternativo: X-Cron-Secret: TU_SECRETO
# CRON_SYNC_SECRET=

JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-characters

ADMIN_EMAIL=admin@example.com
SITE_URL=http://localhost/website

RESEND_API_KEY=

DB_HOST=127.0.0.1
# Deja DB_NAME vacío si aún no usas MySQL (evita error de conexión al arrancar).
DB_NAME=
DB_USER=root
DB_PASS=

WHATSAPP_BUSINESS_NUMBER=17736812440
